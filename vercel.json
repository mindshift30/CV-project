{
  "version": 2,
  "name": "cv-project",
  "builds": [
    {
      "src": "php/api.php",
      "use": "vercel-php@0.7.2"
    },
    {
      "src": "php/config.php",
      "use": "vercel-php@0.7.2"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/php/api.php"
    },
    {
      "src": "/php/api.php(.*)",
      "dest": "/php/api.php$1"
    }
  ],
  "env": {
    "MYSQL_HOST":     "@mysql_host",
    "MYSQL_PORT":     "@mysql_port",
    "MYSQL_USER":     "@mysql_user",
    "MYSQLPASSWORD":  "@mysql_password",
    "MYSQL_DATABASE": "@mysql_database"
  }
}
